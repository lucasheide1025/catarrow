// firestore.rules
// 部署指令：firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 輔助函式
    function isAdmin() {
      return isLoggedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isLoggedIn() {
      return request.auth != null;
    }
    function ownsMember(memberId) {
      return isLoggedIn()
        && exists(/databases/$(database)/documents/members/$(memberId))
        && (
          get(/databases/$(database)/documents/members/$(memberId)).data.uid == request.auth.uid
          || (request.auth.token.email != null
            && get(/databases/$(database)/documents/members/$(memberId)).data.email == request.auth.token.email)
        );
    }

    // admins 集合：本人可讀自己的（登入時判斷身份用），禁止寫入
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // members：admin 全權操作，會員可讀自己；list（集合查詢）任意登入者可用（排行榜需要）
    // 2026-07-09 新增訪客/兒童帳號（accountType in ["guest","kid"]）：匿名登入即可讀寫自己建立的記錄，
    // 且「不要求 uid 對應本人」——因為訪客每次匿名重新登入 uid 都會變，要能跨次造訪接續回同一筆記錄。
    // 這是使用者已確認接受的安全取捨（訪客/兒童帳號沒有真實金流/隱私資料，安全等級刻意低於正式學籍）。
    match /members/{memberId} {
      function activeProfile() {
        return resource.data.get("accountType", "official") != "kid"
          || (resource.data.expiresAt is timestamp && request.time < resource.data.expiresAt);
      }
      function ownsProfile() {
        return isLoggedIn() && (resource.data.uid == request.auth.uid
          || (request.auth.token.email != null && resource.data.email == request.auth.token.email));
      }
      // Guest/kid accounts use anonymous auth whose uid changes each session,
      // so we also allow any logged-in user to read/write active guest/kid profiles.
      // The field-level restrictions still apply on update for guest/kid.
      allow get: if isAdmin() || (ownsProfile() && activeProfile()) || (isLoggedIn() && resource.data.accountType in ["guest", "kid"] && activeProfile());
      allow list: if isAdmin() || (ownsProfile() && activeProfile()) || (isLoggedIn() && resource.data.accountType in ["guest", "kid"] && activeProfile());
      allow create: if isAdmin() || (
        isLoggedIn()
        && request.resource.data.accountType in ["guest", "kid"]
        && request.resource.data.uid == request.auth.uid
        && (request.resource.data.accountType != "kid" || (
          request.resource.data.lifecycle == "qr-temporary"
          && request.resource.data.coins == 500
          && request.resource.data.starterCoinsGranted == true
          && request.resource.data.keys().hasOnly([
            "accountType", "lifecycle", "uid", "name", "nickname",
            "sessionSourceId", "createdViaQR", "coins", "starterCoinsGranted",
            "guestEquipmentSeeded", "rpgEquip", "unlockedEquipItems",
            "createdAt", "lastLoginAt", "expiresAt"
          ])
          && request.resource.data.sessionSourceId is string
          && request.resource.data.sessionSourceId.size() > 0
          && (request.resource.data.sessionSourceId == "fixed-guest-qr" || (
            exists(/databases/$(database)/documents/campSessions/$(request.resource.data.sessionSourceId))
            && get(/databases/$(database)/documents/campSessions/$(request.resource.data.sessionSourceId)).data.active == true
          ))
          && request.resource.data.expiresAt is timestamp
          && request.resource.data.createdAt == request.time
          && request.resource.data.expiresAt > request.time
          // 3h window instead of 2h to tolerate client/server clock skew
          // (expiresAt is computed from client Date.now() + 2h, but evaluated
          //  against server request.time).
          && request.resource.data.expiresAt <= request.time + duration.value(3, 'h')
          && request.resource.data.coins == 500
          && request.resource.data.starterCoinsGranted == true
          && request.resource.data.guestEquipmentSeeded == true
          && request.resource.data.rpgEquip.keys().hasOnly(["bow"])
          && request.resource.data.rpgEquip.bow.itemId == "bow_practice"
          && request.resource.data.rpgEquip.bow.grade == "common"
          && request.resource.data.rpgEquip.bow.plusLevel == 0
          && request.resource.data.rpgEquip.bow.keys().hasOnly(["itemId", "grade", "plusLevel"])
          && request.resource.data.unlockedEquipItems.keys().hasOnly(["bow_practice"])
          && request.resource.data.unlockedEquipItems.bow_practice == true
        ))
      );
      allow delete: if isAdmin();
      // Guest/kid accounts use anonymous auth whose uid changes each session,
      // so the uid/email-based ownsProfile check would reject legitimate updates.
      // The field-level whitelist still applies for write safety.
      allow update: if isAdmin() || (
        ownsProfile() && activeProfile()
        && request.resource.data.get("uid", null) == resource.data.get("uid", null)
        && request.resource.data.get("accountType", "official") == resource.data.get("accountType", "official")
        && request.resource.data.get("expiresAt", null) == resource.data.get("expiresAt", null)
        && request.resource.data.get("createdAt", null) == resource.data.get("createdAt", null)
        && request.resource.data.get("lifecycle", null) == resource.data.get("lifecycle", null)
        && request.resource.data.get("sessionSourceId", null) == resource.data.get("sessionSourceId", null)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastLoginAt", "updatedAt", "equipment", "armorSets", "accessorySets",
          "dailyQuestCount", "eventPoints", "coins", "lastDungeonDate", "equippedCat", "avatarId",
          "lastBattleDate", "monsterSessionsToday", "rpgEquip", "shareSlogan", "nickname",
          "adventurerXP", "archerXP", "arrowMilestoneDone", "promotionDone", "village", "bookingStats",
          "gachaCoins", "catCards", "dungeonCollectibles", "dungeonClearLog", "dungeonFirstKills",
          "dungeonScrollCount", "coinShopPurchases", "unlockedEquipItems", "coinShopRecycle",
          "totalArrowsAllTime", "dungeonExcavation", "expeditionRecords", "lastCheckinDate", "kingSeals",
          "equipmentRuneFragments", "equipmentRuneInventory", "activeExpedition",
          "dungeonBossCardProgress", "expeditions", "starterCoinsGranted", "lastSessionSourceId",
          "teamSavedProgress", "villageBoard",
          "name", "phone"
        ])
      ) || (
        isLoggedIn() && resource.data.accountType in ["guest", "kid"] && activeProfile()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "lastLoginAt", "updatedAt", "equipment", "armorSets", "accessorySets",
          "dailyQuestCount", "eventPoints", "coins", "lastDungeonDate", "equippedCat", "avatarId",
          "lastBattleDate", "monsterSessionsToday", "rpgEquip", "shareSlogan", "nickname",
          "adventurerXP", "archerXP", "arrowMilestoneDone", "promotionDone", "village", "bookingStats",
          "gachaCoins", "catCards", "dungeonCollectibles", "dungeonClearLog", "dungeonFirstKills",
          "dungeonScrollCount", "coinShopPurchases", "unlockedEquipItems", "coinShopRecycle",
          "totalArrowsAllTime", "dungeonExcavation", "expeditionRecords", "lastCheckinDate", "kingSeals",
          "equipmentRuneFragments", "equipmentRuneInventory", "activeExpedition",
          "dungeonBossCardProgress", "expeditions", "starterCoinsGranted", "lastSessionSourceId",
          "teamSavedProgress", "villageBoard",
          "name", "phone"
        ])
      );
    }

    // campSessions：夏令營場次管理，登入者可讀，admin 可寫
    match /campSessions/{sessionId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // competitions：admin 全權，會員可讀；會員可 update（用於報名加入 participants）
    match /competitions/{compId} {
      allow read:   if isLoggedIn();
      allow write:  if isAdmin();
      allow update: if isLoggedIn();
    }

    // results：admin 全權，登入者可讀寫
    // 注意：memberId 存的是 Firestore doc ID，不是 auth.uid，無法在規則層做精確比對
    match /results/{resultId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin() || isLoggedIn();
      allow delete: if isAdmin();
    }

    // registrations：admin 全權，登入者可讀寫自己的
    match /registrations/{regId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // messages：admin 全權，登入者可讀寫
    match /messages/{msgId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin() ||
        (isLoggedIn() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberRead"]));
      allow delete: if isAdmin();
    }

    // Email delivery queue. Only trusted backend code and the Firebase Email
    // extension may access these documents through the Admin SDK, which
    // bypasses Firestore Security Rules. Never expose recipients, message
    // bodies, or delivery status to client applications.
    match /mail/{document} {
      allow read, write: if false;
    }

    // 預約 Email 的內容含營運設定與收件人。管理員可讀取後台畫面；所有寫入都必須
    // 經過 callable function 再做身分、Email、長度與範本 token 驗證。
    match /bookingEmailConfig/{document} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // 測試信節流狀態只供 callable function 使用，不暴露管理員操作時間給前端。
    match /bookingEmailTestRate/{document} {
      allow read, write: if false;
    }

    // 未預約提醒佇列包含 Email 與寄送狀態，只能由後端維護。
    match /bookingReminderQueue/{document} {
      allow read, write: if false;
    }

    // 每日寄送計數器用來跨排程執行強制每日上限，只能由後端維護。
    match /bookingReminderRuns/{document} {
      allow read, write: if false;
    }

    // learnLogs：admin 全權，登入者可讀寫
    match /learnLogs/{logId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // practiceLogs：同上
    match /practiceLogs/{logId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // badgeLogs：admin 全權，登入者可讀；會員可更新領取狀態
    match /badgeLogs/{logId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
      allow update: if isLoggedIn() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "claimedAt", "claimedBy", "disputeReason", "disputedAt", "disputedBy"]);
    }

    // certRecords：admin 全權，登入者可讀
    match /certRecords/{recordId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // achievements：admin 全權，登入者可讀
    match /achievements/{achId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // achievementApplications：登入者可讀自己的、可申請；admin 全權
    match /achievementApplications/{docId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // externalComps：admin 全權，登入者可讀寫
    match /externalComps/{compId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // auditLogs：只有 admin 可讀，系統自動寫入
    match /auditLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if isLoggedIn();
    }

    // monthlyCardRequests：admin 全權；登入者可讀寫
    match /monthlyCardRequests/{reqId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // monthlyCardLogs：admin 全權讀寫
    match /monthlyCardLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if isLoggedIn();
    }

    // monthlyCardConfig：admin 全權；登入者可讀
    match /monthlyCardConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // checkins：admin 全權；登入者可讀寫
    match /checkins/{checkinId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isAdmin() || isLoggedIn();
      allow delete: if isAdmin();
    }

    // dailyQuestConfig：admin 全權；登入者可讀
    match /dailyQuestConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // monsterConfig / monsterEventConfig：admin 全權；登入者可讀
    match /monsterConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // monsterSessions：登入者可讀寫
    match /monsterSessions/{docId} {
      allow read, write: if isLoggedIn();
    }

    // monsterLogs / monsterDex / craftStats：登入者可讀寫
    match /monsterLogs/{docId} {
      allow read, write: if isLoggedIn();
    }
    // 統一射手表現資料：戰鬥完成時由客戶端以固定 sessionId 原子寫入。
    // 子集合 ends 必須明列，父集合規則不會自動涵蓋子集合。
    match /shootingSessions/{sessionId} {
      allow read, write: if isLoggedIn();
      match /ends/{endId} {
        allow read, write: if isLoggedIn();
      }
    }
    match /gamePerformances/{sessionId} {
      allow read, write: if isLoggedIn();
    }
    match /arrowCountEvents/{sessionId} {
      allow read, write: if isLoggedIn();
    }
    // Idempotency markers for locally aggregated arrow progress. A marker can
    // only be created for the caller's own member record and is immutable.
    match /arrowRoundOperations/{operationId} {
      allow get: if isLoggedIn();
      allow list: if false;
      allow create: if isLoggedIn()
        && request.resource.data.memberId is string
        && exists(/databases/$(database)/documents/members/$(request.resource.data.memberId))
        && (
          get(/databases/$(database)/documents/members/$(request.resource.data.memberId)).data.uid == request.auth.uid
          || (request.auth.token.email != null
            && get(/databases/$(database)/documents/members/$(request.resource.data.memberId)).data.email == request.auth.token.email)
          || get(/databases/$(database)/documents/members/$(request.resource.data.memberId)).data.accountType in ["guest", "kid"]
        );
      allow update, delete: if false;
    }
    // Per-member version manifest for local-first performance sync. It holds
    // no raw arrows; clients compare this one small document before fetching
    // changed sessions into their persistent IndexedDB cache.
    match /memberPerformanceSync/{memberId} {
      allow read, write: if isAdmin() || ownsMember(memberId);
    }
    match /monsterDex/{docId} {
      allow read, write: if isLoggedIn();
    }
    match /craftStats/{docId} {
      allow read, write: if isLoggedIn();
    }

    // duelRooms / duelStats：登入者可讀寫
    match /duelRooms/{docId} {
      allow read, write: if isLoggedIn();
    }
    match /duelStats/{docId} {
      allow read, write: if isLoggedIn();
    }

    // partyRooms / partyConfig：登入者可讀寫
    match /partyRooms/{docId} {
      allow read, write: if isLoggedIn();
    }
    match /partyConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // billingRecords：僅教練可讀寫（財務資料）
    match /billingRecords/{recId} {
      allow read, write: if isAdmin();
    }

    // notifications：登入者可讀寫，刪除限 admin
    match /notifications/{notifId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // certifications：射手證任務進度，登入者可讀寫
    match /certifications/{docId} {
      allow read, write: if isLoggedIn();
    }

    // certConfig：射手證設定，admin 寫，登入者讀
    match /certConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // dexGrants：圖鑑授予（admin 操作），登入者可讀
    match /dexGrants/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // dexConfig：圖鑑屆數設定，admin 寫，登入者讀
    match /dexConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // guestSessions：訪客戰鬥，免登入可讀寫（3小時過期）
    match /guestSessions/{docId} {
      allow read, write: if true;
    }

    // guestNotifications：訪客留信箱，免登入可寫，禁讀
    match /guestNotifications/{docId} {
      allow write: if true;
      allow read:  if false;
    }

    // storyChapterConfig：故事本章節設定，admin 寫，登入者讀
    match /storyChapterConfig/{key} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // 遊戲背包（素材/寶箱/藥水/碎片）：登入者可讀寫
    match /materialInventory/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }
    // 裝備專精（design.md §8）：解鎖/升級/切換,transaction 內驗證金幣與素材
    match /equipSpecializations/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }
    // 新版怪物獎勵冪等憑證。正式上線前仍須把獎勵數值計算移至
    // 可信任的 server/callable 邊界；此規則只限制憑證歸屬與不可修改。
    match /monsterRewardClaims/{claimId} {
      // `get` must also permit a missing document so a transaction can test
      // whether this claim id already exists before creating it.
      allow get: if isLoggedIn();
      allow list: if false;
      allow create: if false;
      allow update, delete: if false;
    }
    match /dungeonBossChoiceClaims/{claimId} {
      allow get: if isLoggedIn();
      allow list: if false;
      allow create: if false;
      allow update, delete: if false;
    }
    match /chestInventory/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }
    match /potionInventory/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }
    match /fragmentInventory/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }
    match /chestStats/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }
    match /potionDex/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }

    // cardCollections：卡牌收集，登入者可讀寫
    match /cardCollections/{docId} {
      allow read, write: if isAdmin() || ownsMember(docId);
    }

    // sysConfig：系統設定（版本號等），登入者可讀，admin 可寫
    match /sysConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin() && docId != "costControl";
    }
    match /sysConfig/costControl {
      allow read: if isLoggedIn();
      allow create, update: if isAdmin()
        && request.resource.data.level in ["normal", "warning", "protect", "restricted", "emergency"]
        && request.resource.data.monthlyCeilingTwd is number
        && request.resource.data.monthlyCeilingTwd > 0
        && request.resource.data.observedPercent is number
        && request.resource.data.observedPercent >= 0
        && request.resource.data.revision is int
        && request.resource.data.revision >= 0;
      allow delete: if false;
    }
    match /equipItems/{id} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // dungeonRooms：地下城多人房間，登入者可讀寫
    match /dungeonRooms/{roomId} {
      allow read, write: if isLoggedIn();
    }

    // villageBoardRooms：貓貓村大富翁組隊房間，登入者可讀寫
    match /villageBoardRooms/{roomId} {
      allow read, write: if isLoggedIn();
    }

    // zombieRooms：殭屍生存模式房間（Phase 0）
    // Phase 0 使用寬鬆規則（比照 dungeonRooms/partyRooms），
    // 後續 Phase 加入主機驗證與欄位層級控管。
    // Phase 1+ 限制：只有房主可執行 startShooting / submitRound 等指令；
    // 成員只能提交自己的箭矢記錄。
    match /zombieRooms/{roomId} {
      allow read, write: if isLoggedIn();

      // 子集合：遭遇事件日誌
      match /roundEvents/{eventId} {
        allow read, write: if isLoggedIn();
      }

      // 子集合：已清除 BOSS 標記
      match /clearedBosses/{bossId} {
        allow read, write: if isLoggedIn();
      }
    }

    // worldBossEvents：世界大 Boss 活動，登入者可讀寫
    match /worldBossEvents/{eventId} {
      allow read, write: if isLoggedIn();
    }

    // worldBossHistory：歷史紀錄，登入者可讀，管理員可寫
    match /worldBossHistory/{docId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    // dungeonFirstClear：首殺記錄（登入者可讀寫，由 trySetDungeonFirstClear 原子寫入）
    match /dungeonFirstClear/{dungeonId} {
      allow read:  if isLoggedIn();
      allow write: if isLoggedIn();
    }

    // dungeonBroadcasts：地下城首殺廣播（登入者可讀寫，用於全域通知）
    match /dungeonBroadcasts/{broadcastId} {
      allow read:  if isLoggedIn();
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // 貓咪陪練：subcollection 在 members/{id}/cats/{catId}
    // 只有本人或教練可讀寫（透過 members doc 確認 uid）
    match /members/{memberId}/cats/{catId} {
      allow read, write: if isAdmin()
        || (isLoggedIn() && get(/databases/$(database)/documents/members/$(memberId)).data.uid == request.auth.uid);
    }
    // guildQuests：任務公告，登入者可讀；admin 可寫
    match /guildQuests/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // guildQuestSubs：徽章任務提交審核
    match /guildQuestSubs/{docId} {
      allow read:          if isAdmin();
      allow create:        if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // guildProgress：每位會員的公會任務進度（今日完成 + 已提交懸賞）
    match /guildProgress/{docId} {
      allow read, write: if isLoggedIn();
    }

    // coachChallenges：教練挑戰賽申請
    match /coachChallenges/{docId} {
      allow create:        if isLoggedIn();
      allow read, update:  if isAdmin();
    }

    // councilSessions：議會廳每日採集次數紀錄，登入者可讀寫；admin 可刪（重置）
    match /councilSessions/{docId} {
      allow read, write: if isLoggedIn();
    }

    // villageGoals：村莊共同目標，登入者可讀/貢獻；admin 可建立/刪除
    match /villageGoals/{docId} {
      allow read:   if isLoggedIn();
      allow create: if isAdmin() || isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // cardMarket：貓咪卡片市集，登入者可讀寫
    match /cardMarket/{docId} {
      function listingEscrowDeltaIsValid() {
        let sellerPath = /databases/$(database)/documents/members/$(request.resource.data.sellerId);
        let before = get(sellerPath).data;
        let after = getAfter(sellerPath).data;
        let cardId = request.resource.data.cardId;
        return before.catCards.get(cardId, 0) >= 2
          && after.catCards.get(cardId, 0) == before.catCards.get(cardId, 0) - 1
          && after.diff(before).affectedKeys().hasOnly(["catCards"])
          && after.catCards.diff(before.catCards).affectedKeys().hasOnly([cardId]);
      }

      function cancelledCardReturnDeltaIsValid() {
        let sellerPath = /databases/$(database)/documents/members/$(resource.data.sellerId);
        let before = get(sellerPath).data;
        let after = getAfter(sellerPath).data;
        let cardId = resource.data.cardId;
        return after.catCards.get(cardId, 0) == before.catCards.get(cardId, 0) + 1
          && after.diff(before).affectedKeys().hasOnly(["catCards"])
          && after.catCards.diff(before.catCards).affectedKeys().hasOnly([cardId]);
      }

      function sellerProceedsDeltaIsValid() {
        let sellerPath = /databases/$(database)/documents/members/$(resource.data.sellerId);
        let before = get(sellerPath).data;
        let after = getAfter(sellerPath).data;
        let paymentType = resource.data.priceType;
        let price = resource.data.priceAmount;
        return (
          paymentType == "arrowdew"
          && after.village.resources.arrowdew == before.village.resources.arrowdew + price
          && after.diff(before).affectedKeys().hasOnly(["village"])
          && after.village.diff(before.village).affectedKeys().hasOnly(["resources"])
          && after.village.resources.diff(before.village.resources).affectedKeys().hasOnly(["arrowdew"])
        ) || (
          paymentType == "gachaToken"
          && after.gachaCoins == before.gachaCoins + price
          && after.diff(before).affectedKeys().hasOnly(["gachaCoins"])
        ) || (
          paymentType == "card"
          && resource.data.offeredCardId is string
          && after.catCards.get(resource.data.offeredCardId, 0)
            == before.catCards.get(resource.data.offeredCardId, 0) + 1
          && after.diff(before).affectedKeys().hasOnly(["catCards"])
          && after.catCards.diff(before.catCards).affectedKeys().hasOnly([resource.data.offeredCardId])
        );
      }

      function buyerAssetDeltaIsValid() {
        let buyerPath = /databases/$(database)/documents/members/$(request.resource.data.buyerId);
        let before = get(buyerPath).data;
        let after = getAfter(buyerPath).data;
        let cardId = resource.data.cardId;
        let paymentType = resource.data.priceType;
        let price = resource.data.priceAmount;
        return after.catCards.get(cardId, 0) == before.catCards.get(cardId, 0) + 1
          && (
            (
              paymentType == "arrowdew"
              && after.village.resources.arrowdew == before.village.resources.arrowdew - price
              && after.village.resources.arrowdew >= 0
              && after.diff(before).affectedKeys().hasOnly(["catCards", "village"])
              && after.catCards.diff(before.catCards).affectedKeys().hasOnly([cardId])
              && after.village.diff(before.village).affectedKeys().hasOnly(["resources"])
              && after.village.resources.diff(before.village.resources).affectedKeys().hasOnly(["arrowdew"])
            )
            || (
              paymentType == "gachaToken"
              && after.gachaCoins == before.gachaCoins - price
              && after.gachaCoins >= 0
              && after.diff(before).affectedKeys().hasOnly(["catCards", "gachaCoins"])
              && after.catCards.diff(before.catCards).affectedKeys().hasOnly([cardId])
            )
            || (
              paymentType == "card"
              && request.resource.data.offeredCardId is string
              && request.resource.data.offeredCardId != cardId
              && after.catCards[request.resource.data.offeredCardId]
                == before.catCards[request.resource.data.offeredCardId] - 1
              && after.catCards[request.resource.data.offeredCardId] >= 1
              && after.diff(before).affectedKeys().hasOnly(["catCards"])
              && after.catCards.diff(before.catCards).affectedKeys().hasOnly([
                cardId, request.resource.data.offeredCardId
              ])
            )
          );
      }
      allow read: if isLoggedIn();
      allow create: if isAdmin() || (
        ownsMember(request.resource.data.sellerId)
        && request.resource.data.status == "active"
        && request.resource.data.sellerId is string
        && request.resource.data.cardId is string
        && request.resource.data.priceType in ["arrowdew", "gachaToken", "card"]
        && request.resource.data.priceAmount is number
        && request.resource.data.priceAmount > 0
        && listingEscrowDeltaIsValid()
      );
      allow update: if isAdmin() || (
        // Seller may cancel only an active listing without rewriting its identity/economy fields.
        (
          ownsMember(resource.data.sellerId)
          && resource.data.status == "active"
          && request.resource.data.status == "cancelled"
          && cancelledCardReturnDeltaIsValid()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        )
        // A buyer may transition an active listing to sold, but cannot change seller/card/price.
        || (
          resource.data.status == "active"
          && request.resource.data.status == "sold"
          && ownsMember(request.resource.data.buyerId)
          && request.resource.data.buyerId != resource.data.sellerId
          && request.resource.data.sellerClaimed == false
          && buyerAssetDeltaIsValid()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status", "buyerId", "buyerName", "soldAt", "sellerClaimed", "offeredCardId"
          ])
        )
        // After sale, only the seller may mark proceeds claimed.
        || (
          ownsMember(resource.data.sellerId)
          && resource.data.status == "sold"
          && request.resource.data.status == "sold"
          && resource.data.sellerClaimed == false
          && request.resource.data.sellerClaimed == true
          && sellerProceedsDeltaIsValid()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "sellerClaimed", "sellerClaimedAt"
          ])
        )
      );
      allow delete: if isAdmin();
    }

    // systemConfig：學生分級系統維護鎖／權限矩陣設定，登入者可讀，admin 可寫
    match /systemConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // guildBountyTemplates：一般懸賞任務範本池，admin 管理，登入者可讀
    match /guildBountyTemplates/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // guildBountyRewards：一般懸賞難度獎勵表，admin 管理，登入者可讀
    match /guildBountyRewards/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── 線上約課預約系統（07-10-booking-system-student-pilot，學生試用版）──────
    // bookings：memberId 存的是 members collection docId（不是 auth uid，比照專案既有慣例），
    // 用 get() 反查 members/{memberId}.uid 是否等於目前登入者，跟下面 members/{id}/cats 子集合
    // 用的是同一套查法。⚠️ 已知限制：訪客/兒童帳號（accountType in ["guest","kid"]）每次匿名重新
    // 登入 uid 都會變，這條規則只保證「同一次瀏覽器 session 內」建立→查看→取消/改期自己的預約，
    // 跨 session 回訪查詢自己歷史預約不保證讀得到——跟 members 集合本身既有的訪客身份限制是同一種
    // 已知取捨，不是本次新引入的漏洞。
    match /bookings/{bookingId} {
      allow read: if isAdmin() || (
        isLoggedIn() &&
        get(/databases/$(database)/documents/members/$(resource.data.memberId)).data.uid == request.auth.uid
      );
      allow create: if isAdmin() || (
        isLoggedIn() &&
        get(/databases/$(database)/documents/members/$(request.resource.data.memberId)).data.uid == request.auth.uid &&
        (
          request.resource.data.rescheduledFrom == null ||
          (
            request.resource.data.rescheduledFrom is string &&
            getAfter(/databases/$(database)/documents/bookings/$(request.resource.data.rescheduledFrom)).data.rescheduledTo == bookingId &&
            getAfter(/databases/$(database)/documents/bookings/$(request.resource.data.rescheduledFrom)).data.memberId == request.resource.data.memberId &&
            getAfter(/databases/$(database)/documents/bookings/$(request.resource.data.rescheduledFrom)).data.status == "cancelled"
          )
        )
      );
      // 學生只能改自己預約的 status（取消用；改期是「新建一筆 + 把舊那筆標記 cancelled」，
      // 不是直接改日期時段），不能亂改別人的或改金額/時段以外的欄位。
      allow update: if isAdmin() || (
        isLoggedIn() &&
        get(/databases/$(database)/documents/members/$(resource.data.memberId)).data.uid == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt", "cancelledAt", "checkinId", "rescheduledTo"]) &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["rescheduledTo"]) ||
          (
            resource.data.status == "confirmed" &&
            request.resource.data.status == "cancelled" &&
            request.resource.data.rescheduledTo is string &&
            getAfter(/databases/$(database)/documents/bookings/$(request.resource.data.rescheduledTo)).data.rescheduledFrom == bookingId &&
            getAfter(/databases/$(database)/documents/bookings/$(request.resource.data.rescheduledTo)).data.memberId == resource.data.memberId &&
            getAfter(/databases/$(database)/documents/bookings/$(request.resource.data.rescheduledTo)).data.status == "confirmed"
          )
        )
      );
      allow delete: if false; // 一律用 status 標記，不真的刪除文件
    }

    // bookingSlotCounts：容量計數器，slotKey = "YYYY-MM-DD_HH:mm"，不含個資，
    // 讀寫都只要求登入即可（跟訪客模式類似的寬鬆取捨），實際容量正確性由 bookingDb.js 的
    // runTransaction 保護，不是靠規則層擋。
    match /bookingSlotCounts/{slotKey} {
      allow read, write: if isLoggedIn();
    }
  }
}
