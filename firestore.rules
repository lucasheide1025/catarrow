// firestore.rules
// 部署指令：firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 輔助函式
    function isAdmin() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isMember(memberId) {
      return request.auth.uid == memberId;
    }
    function isLoggedIn() {
      return request.auth != null;
    }

    // admins 集合：本人可讀自己的（登入時判斷身份用），禁止寫入
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // members：admin 全權操作，會員可讀自己（uid 欄位或 email 欄位比對）
    match /members/{memberId} {
      allow read:  if isAdmin()
        || resource.data.uid   == request.auth.uid
        || resource.data.email == request.auth.token.email;
      allow write: if isAdmin();
      allow update: if (resource.data.uid == request.auth.uid || resource.data.email == request.auth.token.email)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["lastLoginAt", "equipment", "uid"]);
    }

    // competitions：admin 全權，會員可讀
    match /competitions/{compId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // results：admin 全權，會員可新增自己的
    match /results/{resultId} {
      allow read:  if isLoggedIn();
      allow create: if isLoggedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // registrations：admin 全權，會員可讀寫自己的
    match /registrations/{regId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // messages：admin 全權，會員可讀寫自己的
    match /messages/{msgId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isAdmin() || 
        (isMember(resource.data.memberId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberRead"]));
      allow delete: if isAdmin();
    }

    // learnLogs：admin 全權，會員可讀寫自己的
    match /learnLogs/{logId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // practiceLogs：同上
    match /practiceLogs/{logId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // badgeLogs：admin 全權，會員可讀並更新領取狀態
    match /badgeLogs/{logId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow write:  if isAdmin();
      allow update: if isMember(resource.data.memberId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "claimedAt", "claimedBy", "disputeReason", "disputedAt", "disputedBy"]);
    }

    // certRecords：admin 全權，會員可讀自己的
    match /certRecords/{recordId} {
      allow read:  if isAdmin() || resource.data.memberId == request.auth.uid;
      allow write: if isAdmin();
    }

    // achievements：admin 全權，會員可讀
    match /achievements/{achId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // externalComps：admin 全權，會員可讀寫自己的
    match /externalComps/{compId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // auditLogs：只有 admin 可讀，系統自動寫入
    match /auditLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if isLoggedIn();
    }

    // monthlyCardRequests：admin 全權；會員可建立自己的 + 讀自己的
    match /monthlyCardRequests/{reqId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // monthlyCardLogs：admin 全權讀寫（追加式紀錄）
    match /monthlyCardLogs/{logId} {
      allow read:  if isAdmin();
      allow write: if isLoggedIn(); // admin 操作時寫入
    }

    // monthlyCardConfig：admin 全權；登入者可讀（前台需要預設次數）
    match /monthlyCardConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // checkins：admin 全權；會員可建立/讀自己的，可更新自己的（問卷達標等）
    match /checkins/{checkinId} {
      allow read:   if isAdmin() || resource.data.memberId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.memberId == request.auth.uid;
      allow update: if isAdmin() || isMember(resource.data.memberId);
      allow delete: if isAdmin();
    }

    // dailyQuestConfig：admin 全權；登入者可讀
    match /dailyQuestConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // monsterConfig / monsterEventConfig：admin 全權；登入者可讀
    match /monsterConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // monsterSessions：admin 全權；登入者可讀寫（遊戲進行時）
    match /monsterSessions/{docId} {
      allow read, write: if isLoggedIn();
    }

    // monsterLogs / monsterDex / craftStats：登入者可讀寫
    match /monsterLogs/{docId} {
      allow read, write: if isLoggedIn();
    }
    match /monsterDex/{docId} {
      allow read, write: if isLoggedIn();
    }
    match /craftStats/{docId} {
      allow read, write: if isLoggedIn();
    }

    // duelRooms / duelStats：登入者可讀寫
    match /duelRooms/{docId} {
      allow read, write: if isLoggedIn();
    }
    match /duelStats/{docId} {
      allow read, write: if isLoggedIn();
    }

    // partyRooms / partyConfig：登入者可讀寫
    match /partyRooms/{docId} {
      allow read, write: if isLoggedIn();
    }
    match /partyConfig/{docId} {
      allow read:  if isLoggedIn();
      allow write: if isAdmin();
    }

    // billingRecords：僅教練可讀寫（財務資料）
    match /billingRecords/{recId} {
      allow read, write: if isAdmin();
    }

    // notifications：全體廣播 + 個人通知，登入者可讀寫（成就公告、加油等）
    match /notifications/{notifId} {
      allow read:   if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if isAdmin();
    }
  }
}
